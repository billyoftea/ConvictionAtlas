{
  "name": "conviction-atlas",
  "version": "1.0.0",
  "description": "Conviction Atlas MVP for Web3 AI fund managers",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npx nx serve api\" \"npm run dev:web\"",
    "dev:api": "npx nx serve api",
    "dev:web": "node scripts/ensure-next-devtools-theme.js && npx next dev ./web -p 3000",
    "clean:web": "node -e \"require('fs').rmSync('web/.next',{recursive:true,force:true})\"",
    "dev:web:reset": "npm run clean:web && npm run dev:web",
    "build": "npx nx run-many -t build --projects=api,web",
    "backend:daily": "python backend/scripts/run_backend.py daily-run",
    "backend:daily:dry": "python backend/scripts/run_backend.py daily-run --dry-run",
    "backend:backtest:1y": "python backend/scripts/run_backend.py backtest-1y",
    "backend:backtest:30d": "python backend/scripts/run_backend.py backtest-30d",
    "backend:dashboard": "python backend/scripts/run_backend.py build-dashboard",
    "backend:payment:test": "python backend/scripts/run_backend.py payment-test",
    "backend:smoke": "python -m compileall backend/src",
    "db:generate": "npx prisma generate",
    "db:push": "npx tsx scripts/db-push.ts",
    "db:migrate": "npm run db:push",
    "db:seed": "npx tsx prisma/seed.ts",
    "setup": "npm run db:generate && npm run db:push && npm run db:seed",
    "pipeline": "npx tsx scripts/run-pipeline.ts",
    "pipeline:fast": "cross-env SKIP_MEMOS=1 npx tsx scripts/run-pipeline.ts",
    "data:export": "npx tsx scripts/export-local-data.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "private": true,
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/js": "22.6.0",
    "@nx/nest": "^22.6.0",
    "@nx/next": "^22.6.0",
    "@nx/node": "22.6.0",
    "@nx/web": "22.6.0",
    "@nx/webpack": "22.6.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "nx": "22.6.0",
    "prettier": "~3.6.2",
    "prisma": "^6.19.2",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "webpack-cli": "^5.1.4"
  },
  "nx": {},
  "dependencies": {
    "@bankofai/x402": "^0.4.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.19.2",
    "@x402/core": "^2.7.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "next": "^15.5.6",
    "openai": "^6.32.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "reflect-metadata": "^0.1.13",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1",
    "tronweb": "^6.2.2"
  }
}
