{
  "name": "conviction-atlas",
  "version": "1.0.0",
  "description": "Conviction Atlas MVP for Web3 AI fund managers",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npx nx serve api\" \"npx next dev ./web -p 3000\"",
    "dev:api": "npx nx serve api",
    "dev:web": "npx next dev ./web -p 3000",
    "build": "npx nx run-many -t build --projects=api,web",
    "db:generate": "npx prisma generate",
    "db:push": "node node_modules/tsx/dist/cli.mjs scripts/db-push.ts",
    "db:migrate": "npm run db:push",
    "db:seed": "node node_modules/tsx/dist/cli.mjs prisma/seed.ts",
    "setup": "npm run db:generate && npm run db:push && npm run db:seed",
    "pipeline": "node node_modules/tsx/dist/cli.mjs scripts/run-pipeline.ts",
    "pipeline:fast": "SKIP_MEMOS=1 node node_modules/tsx/dist/cli.mjs scripts/run-pipeline.ts",
    "data:export": "node node_modules/tsx/dist/cli.mjs scripts/export-local-data.ts",
    "seed:demo": "node node_modules/tsx/dist/cli.mjs scripts/seed-demo-data.ts",
    "seed:hybrid": "node node_modules/tsx/dist/cli.mjs scripts/seed-simulated-signals-and-nav.ts",
    "deploy:web:prod": "bash scripts/deploy-web-prod.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "private": true,
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/js": "22.6.0",
    "@nx/nest": "^22.6.0",
    "@nx/next": "^22.6.0",
    "@nx/node": "22.6.0",
    "@nx/web": "22.6.0",
    "@nx/webpack": "22.6.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "nx": "22.6.0",
    "prettier": "~3.6.2",
    "prisma": "^6.19.2",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "webpack-cli": "^5.1.4"
  },
  "nx": {},
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.19.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^9.6.0",
    "next": "^15.5.6",
    "openai": "^6.32.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "reflect-metadata": "^0.1.13",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1",
    "three": "^0.183.2"
  }
}
